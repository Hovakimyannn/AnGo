{# --- MAP SELECTOR MODAL --- #}
<div id="angoMapSelectorModal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center p-4 bg-black/60 backdrop-blur-sm transition-opacity duration-300 opacity-0 pointer-events-none">
    <div class="bg-white w-full max-w-sm rounded-t-3xl sm:rounded-3xl shadow-2xl overflow-hidden transform translate-y-full sm:translate-y-4 transition-transform duration-300">
        <div class="p-6">
            <h3 class="text-xl font-bold text-gray-900 mb-2">Ընտրեք քարտեզը</h3>
            <p class="text-gray-500 text-sm mb-6">Ինչո՞վ բացել հասցեն՝ {{ _footer_address }}</p>
            
            <div class="space-y-3">
                <a href="https://www.google.com/maps?q=40.150267,44.516867" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 hover:bg-pink-50 border border-transparent hover:border-pink-100 transition group">
                    <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-white shadow-sm overflow-hidden p-1">
                        <img src="https://www.google.com/images/branding/product/2x/maps_96in128dp.png" alt="Google Maps" class="w-full h-full object-contain">
                    </div>
                    <div class="flex-grow">
                        <span class="block font-bold text-gray-900">Google Maps</span>
                    </div>
                    <i class="fas fa-chevron-right text-gray-300 group-hover:text-pink-400"></i>
                </a>

                <a href="https://yandex.com/maps/?ll=44.516867,40.150267&z=18&text=40.150267,44.516867" target="_blank" rel="noopener" class="flex items-center gap-4 p-4 rounded-2xl bg-gray-50 hover:bg-pink-50 border border-transparent hover:border-pink-100 transition group">
                    <div class="w-10 h-10 flex items-center justify-center rounded-xl bg-white shadow-sm overflow-hidden p-1">
                        <img src="https://favicon.yandex.net/favicon/v2/https://maps.yandex.ru/?size=32" alt="Yandex Maps" class="w-full h-full object-contain">
                    </div>
                    <div class="flex-grow">
                        <span class="block font-bold text-gray-900">Yandex Maps</span>
                    </div>
                    <i class="fas fa-chevron-right text-gray-300 group-hover:text-pink-400"></i>
                </a>
            </div>

            <button type="button" onclick="window.angoCloseMapSelector()" class="w-full mt-6 py-4 text-sm font-bold text-gray-500 hover:text-gray-900 transition">
                Չեղարկել
            </button>
        </div>
    </div>
</div>

<script>
    window.angoOpenMapSelector = function() {
        const modal = document.getElementById('angoMapSelectorModal');
        const content = modal.querySelector('div');
        modal.classList.remove('hidden', 'pointer-events-none');
        setTimeout(() => {
            modal.style.opacity = '1';
            content.style.transform = 'translateY(0)';
        }, 10);
    };

    window.angoCloseMapSelector = function() {
        const modal = document.getElementById('angoMapSelectorModal');
        const content = modal.querySelector('div');
        modal.style.opacity = '0';
        content.style.transform = window.innerWidth < 640 ? 'translateY(100%)' : 'translateY(16px)';
        setTimeout(() => {
            modal.classList.add('hidden', 'pointer-events-none');
        }, 300);
    };

    // Close on backdrop click
    document.getElementById('angoMapSelectorModal').addEventListener('click', function(e) {
        if (e.target === this) window.angoCloseMapSelector();
    });
</script>

