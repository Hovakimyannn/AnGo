<!DOCTYPE html>
<html lang="hy">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="GsKbQNTzgOBtOY-p6QVbVTu-lDDmH0QCKC1HAkaztJc" />
    <title>{% block title %}ANGO{% endblock %}</title>
    <meta name="description" content="{% block meta_description %}ANGO գեղեցկության սրահ՝ պրոֆեսիոնալ սպասարկում և լավագույն մասնագետներ Երևանում։{% endblock %}">
    <meta name="keywords" content="{% block meta_keywords %}ANGO, գեղեցկության սրահ, Երևան, varsavir, matnahardar, makeup{% endblock %}">
    {# Capture the canonical URL from the child or use the current request path #}
    {% set __ango_canonical_url_raw %}{% block canonical_url %}{% endblock %}{% endset %}
    {% set __ango_canonical_url = __ango_canonical_url_raw|trim ?: absolute_url(app.request.pathinfo) %}

    {% block canonical %}
        <link rel="canonical" href="{{ __ango_canonical_url }}">
    {% endblock %}

    {# Favicons + manifest (served from /public) #}
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="apple-mobile-web-app-title" content="ANGO" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#111827">
    {# Matches Tailwind bg-gray-50 while app.css loads asynchronously #}
    <style>html{background-color:#f9fafb}</style>

    {# Open Graph / social previews #}
    {% set __ango_page_title = block('title')|striptags|trim %}
    {% set __ango_page_desc = block('meta_description')|striptags|trim %}
    {% set __ango_page_url = __ango_canonical_url %}
    {% set __ango_og_title_final = (__ango_og_title is defined and __ango_og_title) ? __ango_og_title : __ango_page_title %}
    {% set __ango_og_desc_final = (__ango_og_description is defined and __ango_og_description) ? __ango_og_description : __ango_page_desc %}
    {% set __ango_og_image = (__ango_og_image is defined and __ango_og_image) ? __ango_og_image : absolute_url(asset('uploads/photos/ango-logo.png') ~ '?v=' ~ asset_version('uploads/photos/ango-logo.png')) %}
    {% set __ango_og_image_alt = (__ango_og_image_alt is defined and __ango_og_image_alt) ? __ango_og_image_alt : 'ANGO' %}
    {% set __ango_og_type = (__ango_og_type is defined and __ango_og_type) ? __ango_og_type : 'website' %}
    <meta property="og:site_name" content="ANGO">
    <meta property="og:title" content="{{ __ango_og_title_final }}">
    <meta property="og:description" content="{{ __ango_og_desc_final }}">
    <meta property="og:type" content="{{ __ango_og_type }}">
    <meta property="og:url" content="{{ __ango_page_url }}">
    <meta property="og:image" content="{{ __ango_og_image }}">
    <meta property="og:image:alt" content="{{ __ango_og_image_alt }}">
    <meta property="og:locale" content="hy_AM">
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ __ango_og_title_final }}">
    <meta name="twitter:description" content="{{ __ango_og_desc_final }}">
    <meta name="twitter:image" content="{{ __ango_og_image }}">
    <meta name="twitter:image:alt" content="{{ __ango_og_image_alt }}">

    {# Tailwind CSS (compiled) — non-blocking load (Lighthouse render-blocking); brief FOUC possible #}
    {% set __ango_app_css_href = asset('build/app.css') ~ '?v=' ~ asset_version('build/app.css') %}
    <link rel="preload" href="{{ __ango_app_css_href }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="{{ __ango_app_css_href }}"></noscript>

    {# Icons #}
    {% set __ango_fa_local_path = 'vendor/fontawesome/css/all.min.css' %}
    {% set __ango_fa_local_ver = asset_version(__ango_fa_local_path) %}
    {% if __ango_fa_local_ver != '0' %}
        <link rel="preload" href="{{ asset(__ango_fa_local_path) }}?v={{ __ango_fa_local_ver }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link href="{{ asset(__ango_fa_local_path) }}?v={{ __ango_fa_local_ver }}" rel="stylesheet"></noscript>
    {% else %}
        <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
        <noscript><link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet"></noscript>
    {% endif %}

    {# Fonts #}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Armenian:wght@300;400;500;600;700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Armenian:wght@300;400;500;600;700&display=swap" rel="stylesheet"></noscript>
    {% block structured_data %}
        {% set __ango_json_opts = constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE') %}
        {% set __ango_site_url = absolute_url(path('app_home')) %}
        {% set __ango_opening_specs = ango_opening_hours_specification(home_settings) %}
        <script type="application/ld+json">
            {{ {
                '@context': 'https://schema.org',
                '@graph': [
                    {
                        '@type': 'WebSite',
                        '@id': __ango_site_url ~ '#website',
                        'url': __ango_site_url,
                        'name': 'ANGO',
                        'inLanguage': 'hy-AM'
                    },
                    {
                        '@type': 'Organization',
                        '@id': __ango_site_url ~ '#organization',
                        'name': 'ANGO',
                        'alternateName': [
                            'ANGO Beauty',
                            'Ango.beauty',
                            'Անգո Բյութի',
                            'ANGO beauty salon Yerevan',
                            'ANGO gexeckutyan srah Yerevanum'
                        ],
                        'url': __ango_site_url,
                        'logo': {
                            '@type': 'ImageObject',
                            'url': __ango_og_image
                        },
                        'sameAs': [
                            'https://www.instagram.com/angobeauty__/',
                            'https://www.facebook.com/profile.php?id=61580633960341'
                        ]
                    },
                    {
                        '@type': 'BeautySalon',
                        '@id': __ango_site_url ~ '#localbusiness',
                        'name': 'ANGO',
                        'alternateName': [
                            'ANGO Beauty',
                            'Ango.beauty',
                            'Անգո Բյութի',
                            'ANGO Գեղեցկության սրահ Երևանում',
                            'ANGO beauty salon Yerevan',
                            'ANGO gexeckutyan srah Yerevanum'
                        ],
                        'description': 'Գեղեցկության սրահ Երևանում (Ռոստովյան 34/1)՝ վարսահարդարում, մատնահարդարում, ոտնահարդարում, դիմահարդարում։ Ամրագրել առցանց։',
                        'url': __ango_site_url,
                        'image': __ango_og_image,
                        'telephone': '+37494649924',
                        'priceRange': '$$',
                        'address': {
                            '@type': 'PostalAddress',
                            'streetAddress': 'Rostovyan 34/1',
                            'addressLocality': 'Yerevan',
                            'addressRegion': 'Yerevan',
                            'addressCountry': 'AM'
                        },
                        'geo': {
                            '@type': 'GeoCoordinates',
                            'latitude': 40.150267,
                            'longitude': 44.516867
                        },
                        'logo': absolute_url(asset('favicon/android-chrome-512x512.png')),
                        'areaServed': [
                            { '@type': 'City', 'name': 'Yerevan', 'alternateName': 'Երևան' },
                            { '@type': 'Country', 'name': 'Armenia', 'alternateName': 'Հայաստան' }
                        ],
                        'openingHoursSpecification': __ango_opening_specs,
                        'parentOrganization': { '@id': __ango_site_url ~ '#organization' }
                    },
                    {
                        '@type': 'WebPage',
                        '@id': __ango_page_url ~ '#webpage',
                        'url': __ango_page_url,
                        'name': __ango_page_title,
                        'description': __ango_page_desc,
                        'inLanguage': 'hy-AM',
                        'isPartOf': { '@id': __ango_site_url ~ '#website' },
                        'about': { '@id': __ango_site_url ~ '#localbusiness' },
                        'primaryImageOfPage': {
                            '@type': 'ImageObject',
                            'url': __ango_og_image
                        }
                    }
                ]
            }|json_encode(__ango_json_opts)|raw }}
        </script>
    {% endblock %}
    {% block head_extra %}{% endblock %}
    {% block stylesheets %}{% endblock %}
</head>
<body class="bg-gray-50 text-gray-800 flex flex-col min-h-screen">

{# --- HEADER --- #}
<header class="fixed w-full bg-white/95 backdrop-blur shadow-sm z-50 transition-all duration-300 h-16">
    <div class="container mx-auto px-4 h-full flex justify-between items-center">
        <!-- Logo -->
        <a href="{{ path('app_home') }}" class="flex items-center rounded-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-pink-200">
            <span class="inline-flex items-center rounded-2xl overflow-hidden px-2 py-1 transition duration-200 ease-out transform hover:scale-[1.01]">
                {% set __ango_logo_file = 'ango-logo.png' %}
                {% set __ango_logo_v = asset_version('uploads/photos/' ~ __ango_logo_file) %}
                {% set __ango_logo_base = path('app_image_photo', { filename: __ango_logo_file }) %}
                <picture>
                    <source
                        type="image/webp"
                        srcset="
                            {{ __ango_logo_base ~ '?w=96&fmt=webp&v=' ~ __ango_logo_v }} 96w,
                            {{ __ango_logo_base ~ '?w=192&fmt=webp&v=' ~ __ango_logo_v }} 192w,
                            {{ __ango_logo_base ~ '?w=288&fmt=webp&v=' ~ __ango_logo_v }} 288w
                        "
                        sizes="96px"
                    >
                    <img
                        src="{{ __ango_logo_base ~ '?w=96&fmt=png&v=' ~ __ango_logo_v }}"
                        srcset="
                            {{ __ango_logo_base ~ '?w=96&fmt=png&v=' ~ __ango_logo_v }} 96w,
                            {{ __ango_logo_base ~ '?w=192&fmt=png&v=' ~ __ango_logo_v }} 192w
                        "
                        sizes="96px"
                        width="96"
                        height="56"
                        alt="AnGo Beauty Salon Yerevan Logo"
                        class="w-auto object-contain h-14 max-w-[220px]"
                        loading="eager"
                        decoding="async"
                        fetchpriority="low"
                    >
                </picture>
            </span>
        </a>

        <!-- Desktop Menu -->
        <nav class="hidden md:flex space-x-6 items-center font-medium text-sm text-gray-600">
            <a href="{{ path('app_home') }}" class="hover:text-pink-600 transition">Գլխավոր</a>

            <!-- Artists Dropdown -->
            <div class="relative group">
                <button class="flex items-center hover:text-pink-600 transition gap-1 h-full">
                    Մասնագետներ <i class="fas fa-chevron-down text-xs"></i>
                </button>

                <!-- Fixed Dropdown with Links -->
                <div class="absolute left-0 top-full pt-2 w-48 hidden group-hover:block origin-top-left z-50">
                    <div class="bg-white shadow-xl rounded-lg overflow-hidden border-t-2 border-pink-600">
                        <a href="{{ path('app_artists', {'category': 'hair'}) }}" data-ajax-swap="#artistsContent" class="block px-4 py-2 hover:bg-pink-50 hover:text-pink-600">Վարսահարդարներ</a>
                        <a href="{{ path('app_artists', {'category': 'nails'}) }}" data-ajax-swap="#artistsContent" class="block px-4 py-2 hover:bg-pink-50 hover:text-pink-600">Մատնահարդարներ</a>
                        <a href="{{ path('app_artists', {'category': 'pedicure'}) }}" data-ajax-swap="#artistsContent" class="block px-4 py-2 hover:bg-pink-50 hover:text-pink-600">Ոտնահարդարներ</a>
                        <a href="{{ path('app_artists', {'category': 'makeup'}) }}" data-ajax-swap="#artistsContent" class="block px-4 py-2 hover:bg-pink-50 hover:text-pink-600">Դիմահարդարներ</a>
                    </div>
                </div>
            </div>

            <a href="{{ path('app_service_index') }}" class="hover:text-pink-600 transition">Գնացուցակ</a>
            <a href="{{ path('app_home') }}#about" class="hover:text-pink-600 transition">Մեր մասին</a>
            <a href="{{ path('app_home') }}#contact" class="hover:text-pink-600 transition">Կապ</a>
            <a href="{{ path('app_blog_index') }}" class="hover:text-pink-600 transition">Բլոգ</a>
            <a href="{{ path('app_did_you_know_index') }}" class="hover:text-pink-600 transition">Իսկ դուք գիտեի՞ք, որ...</a>

            {% if app.user %}
                <a href="{{ path('app_profile') }}" class="hover:text-pink-600 transition">
                    <i class="fas fa-user mr-1"></i> Իմ պրոֆիլը
                </a>
                {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_ARTIST') %}
                    <a href="{{ path('admin') }}" class="hover:text-pink-600 transition">
                        <i class="fas fa-cog mr-1"></i> Admin
                    </a>
                {% endif %}
            {% else %}
                <a href="{{ path('app_login') }}" class="hover:text-pink-600 transition">
                    <i class="fas fa-sign-in-alt mr-1"></i> Մուտք
                </a>
                <a href="{{ path('app_signup') }}" class="hover:text-pink-600 transition">
                    <i class="fas fa-user-plus mr-1"></i> Գրանցվել
                </a>
            {% endif %}

            <!-- Booking Button -->
            <a href="#booking" class="bg-gray-900 text-white px-5 py-2.5 rounded-full hover:bg-pink-600 transition shadow-lg transform hover:scale-105 duration-200">
                <i class="far fa-calendar-check mr-2"></i>Ամրագրել
            </a>
        </nav>

        <!-- Mobile Menu Button -->
        <button id="angoMobileMenuButton" type="button" aria-label="Բացել/փակել մենյուն" aria-controls="mobile-menu" aria-expanded="false" class="md:hidden text-2xl text-gray-700 focus:outline-none">
            <i class="fas fa-bars"></i>
        </button>
    </div>

    <!-- Mobile Menu Dropdown -->
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t absolute w-full shadow-lg">
        <a href="{{ path('app_home') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Գլխավոր</a>
        <div class="block px-6 py-3 border-b bg-gray-50">
            <span class="font-semibold text-pink-600 block mb-2">Մասնագետներ</span>
            <div class="pl-4 space-y-2 text-sm text-gray-600 border-l-2 border-pink-200">
                <a href="{{ path('app_artists', {'category': 'hair'}) }}" data-ajax-swap="#artistsContent" class="block py-1">Վարսահարդարներ</a>
                <a href="{{ path('app_artists', {'category': 'nails'}) }}" data-ajax-swap="#artistsContent" class="block py-1">Մատնահարդարներ</a>
                <a href="{{ path('app_artists', {'category': 'pedicure'}) }}" data-ajax-swap="#artistsContent" class="block py-1">Ոտնահարդարներ</a>
                <a href="{{ path('app_artists', {'category': 'makeup'}) }}" data-ajax-swap="#artistsContent" class="block py-1">Դիմահարդարներ</a>
            </div>
        </div>
        <a href="{{ path('app_service_index') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Գնացուցակ</a>
        <a href="{{ path('app_home') }}#about" class="block px-6 py-3 border-b hover:bg-gray-50">Մեր մասին</a>
        <a href="{{ path('app_home') }}#contact" class="block px-6 py-3 border-b hover:bg-gray-50">Կապ</a>
        <a href="{{ path('app_blog_index') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Բլոգ</a>
        <a href="{{ path('app_did_you_know_index') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Իսկ դուք գիտեի՞ք, որ...</a>

        {% if app.user %}
            <a href="{{ path('app_profile') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Իմ պրոֆիլը</a>
            {% if is_granted('ROLE_ADMIN') or is_granted('ROLE_ARTIST') %}
                <a href="{{ path('admin') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Admin</a>
            {% endif %}
            <a href="{{ path('app_logout') }}" class="block px-6 py-3 border-b hover:bg-gray-50 text-red-600 font-semibold">Ելք</a>
        {% else %}
            <a href="{{ path('app_login') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Մուտք</a>
            <a href="{{ path('app_signup') }}" class="block px-6 py-3 border-b hover:bg-gray-50">Գրանցվել</a>
        {% endif %}

        <a href="#booking" class="block px-6 py-3 border-b hover:bg-gray-50 text-pink-600 font-bold">Ամրագրել հիմա</a>
    </div>
</header>

{# --- MAIN CONTENT --- #}
<main class="flex-grow pt-16">
    {% block body %}{% endblock %}
</main>

{# --- FOOTER (admin: Home էջի կարգավորումներ → Կապ / Footer) --- #}
{% set _footer_tagline = (home_settings is defined and home_settings and home_settings.footerTagline is not empty) ? home_settings.footerTagline : "Ձեր գեղեցկությունը մեր ամենակարևոր հոգսն է։\nԼավագույն մասնագետները Երևանում։" %}
{% set _footer_address = (home_settings is defined and home_settings and home_settings.contactAddress is not empty) ? home_settings.contactAddress : 'Ք. Երևան, Ռոստովյան 34/1' %}
{% set _footer_phone = (home_settings is defined and home_settings and home_settings.contactPhone is not empty) ? home_settings.contactPhone : '+374 94 64 99 24' %}
{% set _footer_hours1 = (home_settings is defined and home_settings and home_settings.contactHoursLine1 is not empty) ? home_settings.contactHoursLine1 : 'Երկ - Շաբ: 10:00 - 20:00' %}
{% set _footer_hours2 = (home_settings is defined and home_settings and home_settings.contactHoursLine2 is not empty) ? home_settings.contactHoursLine2 : 'Կիր: 11:00 - 18:00' %}
{% set _footer_instagram = (home_settings is defined and home_settings and home_settings.contactInstagramUrl is not empty) ? home_settings.contactInstagramUrl : 'https://www.instagram.com/angobeauty__/' %}
{% set _footer_facebook = (home_settings is defined and home_settings and home_settings.contactFacebookUrl is not empty) ? home_settings.contactFacebookUrl : 'https://www.facebook.com/profile.php?id=61580633960341' %}
{% set _footer_copyright = (home_settings is defined and home_settings and home_settings.contactCopyrightText is not empty) ? home_settings.contactCopyrightText : 'Բոլոր իրավունքները պաշտպանված են։' %}
<footer class="bg-gray-900 text-white py-16">
    <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
            <!-- Brand & Tagline -->
            <div class="space-y-4">
                <h3 class="text-2xl font-bold text-pink-500">ANGO</h3>
                <p class="text-gray-400 text-sm leading-relaxed">{{ _footer_tagline|nl2br }}</p>
                <div class="flex space-x-4 pt-2">
                    <a href="{{ _footer_instagram }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram" title="Հետևեք մեզ Instagram-ում" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 hover:bg-pink-600 transition duration-300">
                        <i class="fab fa-instagram text-xl"></i>
                    </a>
                    <a href="{{ _footer_facebook }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook" title="Հետևեք մեզ Facebook-ում" class="w-10 h-10 flex items-center justify-center rounded-full bg-gray-800 hover:bg-blue-600 transition duration-300">
                        <i class="fab fa-facebook-f text-lg"></i>
                    </a>
                </div>
            </div>

            <!-- Quick Services Links -->
            <div class="space-y-4">
                <h4 class="font-bold text-lg border-b border-gray-800 pb-2">Ծառայություններ</h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li><a href="{{ path('app_artists', {category: 'hair'}) }}" class="hover:text-pink-500 transition">Վարսահարդարում</a></li>
                    <li><a href="{{ path('app_artists', {category: 'nails'}) }}" class="hover:text-pink-500 transition">Մատնահարդարում</a></li>
                    <li><a href="{{ path('app_artists', {category: 'pedicure'}) }}" class="hover:text-pink-500 transition">Ոտնահարդարում</a></li>
                    <li><a href="{{ path('app_artists', {category: 'makeup'}) }}" class="hover:text-pink-500 transition">Դիմահարդարում</a></li>
                    <li><a href="{{ path('app_service_index') }}" class="hover:text-pink-500 transition">Գնացուցակ</a></li>
                </ul>
            </div>

            <!-- Company Info Links -->
            <div class="space-y-4">
                <h4 class="font-bold text-lg border-b border-gray-800 pb-2">Տեղեկատվություն</h4>
                <ul class="space-y-2 text-sm text-gray-400">
                    <li><a href="{{ path('app_home') }}#about" class="hover:text-pink-500 transition">Մեր մասին</a></li>
                    <li><a href="{{ path('app_home') }}#contact" class="hover:text-pink-500 transition">Հետադարձ կապ</a></li>
                    <li><a href="{{ path('app_blog_index') }}" class="hover:text-pink-500 transition">Բլոգ / Օգտակար խորհուրդներ</a></li>
