{% extends 'base.html.twig' %}

{% set __ango_og_type = 'article' %}
{% set __ango_seo_title = (post.seoTitle ?: post.title)|trim %}
{% set __ango_meta_desc = (post.metaDescription ?: post.excerpt(160))|trim %}
{% set __ango_og_title = (post.ogTitle ?: __ango_seo_title)|trim %}
{% set __ango_og_description = (post.ogDescription ?: __ango_meta_desc)|trim %}
{% if post.ogImageUrl %}
    {% set __og_image_raw = post.ogImageUrl|trim %}
    {% if __og_image_raw starts with 'http://' or __og_image_raw starts with 'https://' %}
        {% set __ango_og_image = __og_image_raw %}
    {% else %}
        {% set __ango_og_image = absolute_url(asset('uploads/posts/' ~ __og_image_raw)) %}
    {% endif %}
{% elseif post.imageUrl %}
    {% set __ango_og_image = absolute_url(asset('uploads/posts/' ~ post.imageUrl)) %}
{% endif %}
{% set __ango_og_image_alt = (post.ogImageAlt ?: post.title)|trim %}

{% block title %}{{ __ango_seo_title }} | ANGO{% endblock %}
{% block meta_description %}{{ __ango_meta_desc }}{% endblock %}
{% block canonical_url %}
    {% if post.canonicalUrl %}
        {{ post.canonicalUrl }}
    {% else %}
        {{ absolute_url(path('app_blog_show', {id: post.id, slug: post.slug})) }}
    {% endif %}
{% endblock %}

{% block structured_data %}
    {{ parent() }}
    {% set __ango_json_opts = constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE') %}
    {% set __ango_site_url = absolute_url(path('app_home')) %}
    {% set __page_url = block('canonical_url')|trim %}
    {% set __author_name = (post.artist.user.firstName ~ ' ' ~ post.artist.user.lastName)|trim %}

    {% set __keywords = [] %}
    {% for s in post.services %}
        {% set __keywords = __keywords|merge([s.name]) %}
    {% endfor %}
    {% set __blog_index_url = absolute_url(path('app_blog_index')) %}
    {% set __breadcrumbs = {
        '@type': 'BreadcrumbList',
        'itemListElement': [
            {
                '@type': 'ListItem',
                'position': 1,
                'name': 'Գլխավոր',
                'item': __ango_site_url
            },
            {
                '@type': 'ListItem',
                'position': 2,
                'name': 'Բլոգ',
                'item': __blog_index_url
            },
            {
                '@type': 'ListItem',
                'position': 3,
                'name': post.title,
                'item': __page_url
            }
        ]
    } %}

    {% set __blog_post = {
        '@type': 'BlogPosting',
        '@id': __page_url ~ '#blogposting',
        'headline': post.title,
        'description': __ango_og_description,
        'url': __page_url,
        'mainEntityOfPage': __page_url,
        'inLanguage': 'hy-AM',
        'author': {
            '@type': 'Person',
            'name': __author_name,
            'url': absolute_url(path('app_artist_show', {slug: post.artist.slug}))
        },
        'publisher': { '@id': __ango_site_url ~ '#organization' },
        'datePublished': (post.publishedAt ? post.publishedAt|date('c') : post.createdAt|date('c')),
        'dateModified': (post.updatedAt ? post.updatedAt|date('c') : (post.publishedAt ? post.publishedAt|date('c') : post.createdAt|date('c'))),
        'keywords': __keywords
    } %}

    {% set __avg = ratingStats.avg|default(0) %}
    {% set __count = ratingStats.count|default(0) %}
    {% if __count > 0 %}
        {% set __blog_post = __blog_post|merge({
            'aggregateRating': {
                '@type': 'AggregateRating',
                'ratingValue': __avg|number_format(1, '.', ''),
                'reviewCount': __count,
                'bestRating': '5',
                'worstRating': '1'
            }
        }) %}
    {% endif %}
    {% if post.imageUrl %}
        {% set __blog_post = __blog_post|merge({'image': absolute_url(asset('uploads/posts/' ~ post.imageUrl))}) %}
    {% endif %}

    <script type="application/ld+json">
        {{ {
            '@context': 'https://schema.org',
            '@graph': [ __breadcrumbs, __blog_post ]
        }|json_encode(__ango_json_opts)|raw }}
    </script>
{% endblock %}

{% block head_extra %}
    {% if post.robotsDirective %}
        <meta name="robots" content="{{ post.robotsDirective|trim }}">
    {% endif %}
    <meta property="article:published_time" content="{{ (post.publishedAt ? post.publishedAt|date('c') : post.createdAt|date('c')) }}">
    <meta property="article:modified_time" content="{{ (post.updatedAt ? post.updatedAt|date('c') : (post.publishedAt ? post.publishedAt|date('c') : post.createdAt|date('c'))) }}">
    <meta property="article:author" content="{{ absolute_url(path('app_artist_show', {slug: post.artist.slug})) }}">
{% endblock %}

{% block body %}
    <div class="bg-white">
        <div class="container mx-auto px-4 py-10">
            <div class="max-w-4xl mx-auto">
                <div class="mb-8">
                    <nav class="text-sm text-gray-500 mb-4">
                        <a href="{{ path('app_home') }}" class="hover:text-pink-600 transition">Գլխավոր</a>
                        <span class="mx-2">/</span>
                        <a href="{{ path('app_blog_index') }}" class="hover:text-pink-600 transition">Բլոգ</a>
                        <span class="mx-2">/</span>
                        <span class="text-gray-800 font-semibold">{{ post.title }}</span>
                    </nav>
                    <a href="{{ path('app_artist_show', {slug: post.artist.slug}) }}" class="text-sm text-gray-500 hover:text-pink-600 transition">
                        ← {{ post.artist.user.firstName }} {{ post.artist.user.lastName }}
                    </a>
                    <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mt-3">{{ post.title }}</h1>

                    {# Social Share Buttons #}
                    <div class="flex items-center gap-3 mt-5 pb-6 border-b border-gray-100">
                        <span class="text-xs font-bold text-gray-400 uppercase tracking-wider">Կիսվել՝</span>
                        {% set __share_url = absolute_url(app.request.requestUri)|url_encode %}
                        {% set __share_title = post.title|url_encode %}

                        <a href="https://www.facebook.com/sharer/sharer.php?u={{ __share_url }}" target="_blank" rel="noopener" 
                           style="background-color: #1877f2; color: white;"
                           class="w-8 h-8 flex items-center justify-center rounded-full hover:opacity-80 transition" title="Կիսվել Facebook-ում">
                            <i class="fab fa-facebook-f text-sm"></i>
                        </a>
                        <a href="https://t.me/share/url?url={{ __share_url }}&text={{ __share_title }}" target="_blank" rel="noopener" 
                           style="background-color: #24A1DE; color: white;"
                           class="w-8 h-8 flex items-center justify-center rounded-full hover:opacity-80 transition" title="Կիսվել Telegram-ում">
                            <i class="fab fa-telegram-plane text-sm"></i>
                        </a>
                        <a href="viber://forward?text={{ __share_title }}%20{{ __share_url }}" 
                           style="background-color: #7360f2; color: white;"
                           class="w-8 h-8 flex items-center justify-center rounded-full hover:opacity-80 transition sm:hidden" title="Կիսվել Viber-ում">
                            <i class="fab fa-viber text-sm"></i>
                        </a>
                        {# Desktop Viber fallback via web #}
                        <a href="https://www.addtoany.com/add_to/viber?linkurl={{ __share_url }}&linkname={{ __share_title }}" target="_blank" rel="noopener" 
                           style="background-color: #7360f2; color: white;"
                           class="w-8 h-8 hidden sm:flex items-center justify-center rounded-full hover:opacity-80 transition" title="Կիսվել Viber-ում">
                            <i class="fab fa-viber text-sm"></i>
                        </a>
                    </div>

                    <div class="flex flex-wrap items-center gap-2 mt-4">
                        {% for s in post.services %}
                            {% set __service_slug = serviceSlugs[s.id]|default('service') %}
                            <a href="{{ path('app_service_show', {id: s.id, slug: __service_slug}) }}"
                               class="text-xs font-semibold bg-pink-50 text-pink-700 px-2 py-1 rounded-full border border-pink-100 hover:bg-pink-100 transition">
                                {{ s.name }}
                            </a>
                        {% endfor %}
                    </div>
                </div>

                {% if post.imageUrl %}
                    <div class="rounded-2xl overflow-hidden border bg-gray-100 mb-8">
                        <img src="{{ asset('uploads/posts/' ~ post.imageUrl) }}"
                             alt="{{ post.title }} — {{ post.artist.user.firstName }} {{ post.artist.user.lastName }} | ANGO Beauty Yerevan"
                             class="w-full h-auto">
                    </div>
                {% endif %}

                <article class="prose max-w-none prose-p:leading-relaxed prose-a:text-pink-600">
                    {{ post.content|raw }}
                </article>

                <div class="mt-12 border-t pt-8">
                    {% set avg = ratingStats.avg|default(0) %}
                    {% set count = ratingStats.count|default(0) %}
                    {% set avgText = avg|number_format(1, '.', '') %}
                    {% set percent = (avg / 5 * 100) %}
                    {% set percent = percent < 0 ? 0 : (percent > 100 ? 100 : percent) %}

                    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-5">
                        <h2 class="text-2xl font-bold">Գնահատական</h2>

                        {# Rating pill (number + stars) #}
                        <div id="ratingPill" class="inline-flex items-center gap-3 px-4 py-2 rounded-full border border-gray-200 bg-white shadow-sm relative">
                            <span id="ratingAvg" class="text-lg font-bold text-gray-900">{{ avgText }}</span>

                            <div class="relative leading-none" aria-label="{{ avgText }} / 5">
                                <div class="flex text-gray-200 text-lg">
                                    {% for i in 1..5 %}
                                        <i class="fas fa-star" aria-hidden="true"></i>
                                    {% endfor %}
                                </div>
                                <div id="ratingFill" class="absolute inset-0 overflow-hidden" data-percent="{{ percent }}">
                                    <div class="flex text-yellow-400 text-lg">
                                        {% for i in 1..5 %}
                                            <i class="fas fa-star" aria-hidden="true"></i>
                                        {% endfor %}
                                    </div>
                                </div>
                            </div>

                            <span id="ratingCount" class="text-sm text-gray-500">({{ count }})</span>

                            <span id="ratingSavedIcon" aria-hidden="true">
                                <i class="fas fa-check" aria-hidden="true"></i>
                            </span>
                        </div>
                    </div>

                    {% if app.user %}
                        <div id="ratingAjaxMessage" class="hidden mb-3 rounded-xl border px-4 py-3 text-sm"></div>

                        <form id="ratingForm" method="post" action="{{ path('app_blog_rate', {id: post.id}) }}" class="flex flex-col gap-3">
                            <input type="hidden" name="_token" value="{{ csrf_token('blog_rate_' ~ post.id) }}">

                            <div class="flex items-center gap-3">
                                <div class="ango-star-rating text-2xl">
                                    {% for i in 5..1 %}
                                        <input type="radio"
                                               id="rate-{{ i }}"
                                               name="value"
                                               value="{{ i }}"
                                               {{ myRating == i ? 'checked' : '' }}>
                                        <label for="rate-{{ i }}" title="{{ i }} / 5" aria-label="{{ i }} / 5">
                                            <i class="fas fa-star" aria-hidden="true"></i>
                                        </label>
                                    {% endfor %}
                                </div>

                                <div class="text-xs text-gray-500">
                                    {{ count == 0 ? 'Դուք կարող եք լինել առաջինը' : 'Շնորհակալություն' }}
                                </div>
                            </div>
                        </form>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-pink-600 font-semibold hover:underline">
                            Մուտք գործեք՝ գնահատելու համար
                        </a>
                    {% endif %}
                </div>

                <div class="mt-12 border-t pt-8">
                    <h2 class="text-2xl font-bold mb-4">Մեկնաբանություններ</h2>

                    {% if app.user %}
                        <div id="commentAjaxMessage" class="hidden mb-3 rounded-xl border px-4 py-3 text-sm"></div>

                        <form id="commentForm" method="post" action="{{ path('app_blog_comment', {id: post.id}) }}" class="mb-8">
                            <input type="hidden" name="_token" value="{{ csrf_token('blog_comment_' ~ post.id) }}">
                            <textarea id="commentBody" name="body" rows="4" class="w-full border rounded-xl p-4 text-sm focus:outline-none focus:ring-2 focus:ring-pink-200" placeholder="Գրեք ձեր կարծիքը..."></textarea>
                            <div class="flex justify-end mt-3">
                                <button id="commentSubmit" class="bg-gray-900 text-white px-6 py-2 rounded-lg text-sm font-semibold hover:bg-pink-600 transition">
                                    Ավելացնել
                                </button>
                            </div>
                        </form>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="text-pink-600 font-semibold hover:underline">
                            Մուտք գործեք՝ մեկնաբանելու համար
                        </a>
                    {% endif %}

                    <div id="commentsList" class="space-y-4">
                        {% if comments|length %}
                            {% for c in comments %}
                                <div class="bg-gray-50 border rounded-2xl p-5">
                                    <div class="flex items-center justify-between">
                                        <div class="font-bold text-gray-900 text-sm">
                                            {{ c.user.firstName }} {{ c.user.lastName }}
                                        </div>
                                        <div class="text-xs text-gray-400">
                                            {{ c.createdAt|date('Y-m-d H:i') }}
                                        </div>
                                    </div>
                                    <div class="text-sm text-gray-700 mt-2 whitespace-pre-line">{{ c.body }}</div>
                                </div>
                            {% endfor %}
                        {% else %}
                            <div id="noComments" class="text-gray-500">
                                Առաջինն եղեք, ով կթողնի մեկնաբանություն։
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    <div id="angoBlogShowConfig" data-login-url="{{ path('app_login') }}" hidden></div>
    <script src="{{ asset('js/blog-show.js') }}?v={{ asset_version('js/blog-show.js') }}" defer></script>
{% endblock %}


