{% extends 'base.html.twig' %}

{% block title %}{{ category }} Երևանում | ANGO{% endblock %}
{% block meta_description %}
    {% set __catKey = app.request.query.get('category') %}
    {% if __catKey == 'hair' %}
        ANGO վարսահարդարներ (վարսավիր) Երևանում։ Տեսեք մասնագետների պրոֆիլները, աշխատանքները և ամրագրեք այցը առցանց։
    {% elseif __catKey == 'nails' %}
        ANGO մատնահարդարներ (մանիկյուր) Երևանում։ Տեսեք մասնագետների պրոֆիլները, աշխատանքները և ամրագրեք այցը առցանց։
    {% elseif __catKey == 'pedicure' %}
        ANGO ոտնահարդարներ (pedicure) Երևանում։ Տեսեք մասնագետների պրոֆիլները, աշխատանքները և ամրագրեք այցը առցանց։
    {% elseif __catKey == 'makeup' %}
        ANGO դիմահարդարներ (makeup artist) Երևանում։ Տեսեք մասնագետների պրոֆիլները, աշխատանքները և ամրագրեք այցը առցանց։
    {% else %}
        ANGO մասնագետներ Երևանում։ Տեսեք մեր մասնագետներին և ամրագրեք այցը առցանց։
    {% endif %}
{% endblock %}

{% block canonical_url %}
    {% set __cat = app.request.query.get('category') %}
    {% set __page = page|default(1) %}
    {% if __cat in ['hair', 'nails', 'pedicure', 'makeup'] %}
        {% set __url = absolute_url(path('app_artists', {category: __cat})) %}
    {% else %}
        {% set __url = absolute_url(path('app_artists')) %}
    {% endif %}
    {% if __page > 1 %}
        {{ __url ~ (('?' in __url) ? '&' : '?') ~ 'page=' ~ __page }}
    {% else %}
        {{ __url }}
    {% endif %}
{% endblock %}

{% block structured_data %}
    {{ parent() }}
    {% set __ango_json_opts = constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE') %}
    {% set __ango_site_url = absolute_url(path('app_home')) %}
    {% set __catKey = app.request.query.get('category') %}
    {% set __seo_keywords = '' %}
    {% if __catKey == 'hair' %}
        {% set __seo_keywords = 'varsahardar yerevanum, varsavir yerevan' %}
    {% elseif __catKey == 'nails' %}
        {% set __seo_keywords = 'matnahardar yerevanum, manikyur yerevan' %}
    {% elseif __catKey == 'pedicure' %}
        {% set __seo_keywords = 'otnahardar yerevanum, pedicure yerevan' %}
    {% elseif __catKey == 'makeup' %}
        {% set __seo_keywords = 'makeup artist yerevan, harsanekan dimahardarum' %}
    {% endif %}

    {% set __artist_list = [] %}
    {% set __position_offset = ((page|default(1) - 1) * (perPage|default(12))) %}
    {% if artists is defined %}
        {% for a in artists %}
            {% set __full_name = (a.user.firstName ~ ' ' ~ a.user.lastName)|trim %}
            {% set __person = {
                '@type': 'Person',
                'name': __full_name,
                'jobTitle': a.specialization,
                'url': absolute_url(path('app_artist_show', {id: a.id})),
                'worksFor': { '@id': __ango_site_url ~ '#localbusiness' }
            } %}
            {% if a.photoUrl %}
                {% set __person = __person|merge({'image': absolute_url(asset('uploads/photos/' ~ a.photoUrl))}) %}
            {% endif %}
            {% set __artist_list = __artist_list|merge([{
                '@type': 'ListItem',
                'position': __position_offset + loop.index,
                'item': __person
            }]) %}
        {% endfor %}
    {% endif %}

    <script type="application/ld+json">
        {{ {
            '@context': 'https://schema.org',
            '@graph': [
                ({
                    '@type': 'ItemList',
                    'name': category,
                    'itemListElement': __artist_list
                } | merge(__seo_keywords ? {'keywords': __seo_keywords} : {}))
            ]
        }|json_encode(__ango_json_opts)|raw }}
    </script>
{% endblock %}

{% block body %}
    <div id="artistsContent" class="container mx-auto px-4 py-12">
        <div class="text-center mb-12">
            <h1 class="text-3xl font-bold mb-4">
                <span class="text-pink-600">{{ category }}</span>
            </h1>
            {% set __catKey = app.request.query.get('category') %}
            {% if __catKey == 'hair' %}
                <p class="text-gray-500 max-w-3xl mx-auto">
                    Վարսահարդարներ / վարսավիրներ՝ Երևանում։ Տեսեք «վարսահարդարի աշխատանքները», ընտրեք մասնագետին և ամրագրեք այցը։
                </p>
            {% elseif __catKey == 'nails' %}
                <p class="text-gray-500 max-w-3xl mx-auto">
                    Մատնահարդարներ՝ մանիկյուր, շելլակ, գել լաք։ Ընտրեք մասնագետին և ամրագրեք այցը։
                </p>
            {% elseif __catKey == 'pedicure' %}
                <p class="text-gray-500 max-w-3xl mx-auto">
                    Ոտնահարդարներ՝ pedicure, խնամք և բուժական մոտեցում։ Ընտրեք մասնագետին և ամրագրեք այցը։
                </p>
            {% elseif __catKey == 'makeup' %}
                <p class="text-gray-500 max-w-3xl mx-auto">
                    Դիմահարդարներ՝ հարսանեկան, երեկոյան և ամենօրյա make-up։ Տեսեք աշխատանքները և ամրագրեք այցը։
                </p>
            {% else %}
                <p class="text-gray-500 max-w-3xl mx-auto">
                    Մեր մասնագետները՝ վարսահարդարում, մատնահարդարում, ոտնահարդարում (pedicure) և դիմահարդարում։ Ընտրեք մասնագետին և ամրագրեք այցը առցանց։
                </p>
            {% endif %}
            <div class="w-24 h-1 bg-gray-200 mx-auto rounded-full"></div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            {% for artist in artists %}
                <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-2xl transition duration-300 group border border-gray-100 relative">
                    <div class="h-80 overflow-hidden relative">
                        {% if artist.photoUrl %}
                            <img src="{{ asset('uploads/photos/' ~ artist.photoUrl) }}"
                                 alt="{{ artist.user.firstName }} {{ artist.user.lastName }}"
                                 class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
                        {% else %}
                            <img src="https://ui-avatars.com/api/?name={{ artist.user.firstName }}+{{ artist.user.lastName }}&background=pink&color=fff&size=512"
                                 alt="{{ artist.user.firstName }} {{ artist.user.lastName }}"
                                 class="w-full h-full object-cover">
                        {% endif %}

                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover:opacity-100 transition duration-300 flex items-end justify-center p-6">
                            <a href="{{ path('app_artist_show', {id: artist.id}) }}" class="relative z-20 text-white font-bold border border-white px-6 py-2 rounded-full hover:bg-white hover:text-black transition">
                                Տեսնել Ավելին
                            </a>
                        </div>
                    </div>
                    <div class="p-6 text-center">
                        <h3 class="text-xl font-bold text-gray-800">{{ artist.user.firstName }} {{ artist.user.lastName }}</h3>
                        <p class="text-pink-600 font-medium text-sm mt-1 mb-4">{{ artist.specialization }}</p>
                    </div>

                    {# Make whole card clickable #}
                    <a href="{{ path('app_artist_show', {id: artist.id}) }}"
                       class="absolute inset-0 z-10"
                       aria-label="{{ artist.user.firstName }} {{ artist.user.lastName }} էջ"></a>
                </div>
            {% else %}
                <div class="col-span-3 text-center py-12">
                    <p class="text-gray-500 text-lg">Այս կատեգորիայում դեռ մասնագետներ գրանցված չեն:</p>
                </div>
            {% endfor %}
        </div>

        {% if totalPages|default(1) > 1 %}
            {% set __cat = app.request.query.get('category') %}
            {% set __base = __cat in ['hair', 'nails', 'pedicure', 'makeup'] ? (path('app_artists', {category: __cat})) : path('app_artists') %}
            <nav class="mt-10 flex flex-wrap items-center justify-center gap-2" aria-label="Pagination">
                {% set __prev_page = page - 1 %}
                {% set __prev_href = __prev_page > 1 ? (__base ~ (('?' in __base) ? '&' : '?') ~ 'page=' ~ __prev_page) : __base %}
                <a href="{{ __prev_href }}" class="px-3 py-2 rounded-lg border text-sm {{ page > 1 ? 'bg-white text-gray-700 hover:bg-gray-50' : 'pointer-events-none text-gray-300 bg-gray-50' }}">‹</a>

                {% for p in 1..totalPages %}
                    {% set __href = p > 1 ? (__base ~ (('?' in __base) ? '&' : '?') ~ 'page=' ~ p) : __base %}
                    <a href="{{ __href }}" class="px-3 py-2 rounded-lg border text-sm {{ p == page ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-700 hover:bg-gray-50' }}">{{ p }}</a>
                {% endfor %}

                {% set __next_page = page + 1 %}
                {% set __next_href = __base ~ (('?' in __base) ? '&' : '?') ~ 'page=' ~ __next_page %}
                <a href="{{ __next_href }}" class="px-3 py-2 rounded-lg border text-sm {{ page < totalPages ? 'bg-white text-gray-700 hover:bg-gray-50' : 'pointer-events-none text-gray-300 bg-gray-50' }}">›</a>
            </nav>
        {% endif %}
    </div>
{% endblock %}
