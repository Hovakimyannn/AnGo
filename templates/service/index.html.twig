{% extends 'base.html.twig' %}

{% block title %}
    {% if category %}
        {{ categoryLabel }} Երևանում | ANGO
    {% else %}
        Ծառայություններ և գներ Երևանում | ANGO
    {% endif %}
{% endblock %}
{% block meta_description %}
    {% if category %}
        ANGO {{ categoryLabel }} ծառայություններ և գներ Երևանում։ Տևողություն, գներ և մասնագետներ՝ մեկ էջում։
    {% else %}
        Վարսահարդարում, մատնահարդարում, ոտնահարդարում և դիմահարդարում Երևանում։ Ծառայությունների ամբողջական ցանկն ու գները ANGO-ում — Ռոստովյան 34/1։
    {% endif %}
{% endblock %}
{% block canonical_url %}
    {% set __route = category ? 'app_service_category' : 'app_service_index' %}
    {% set __params = category ? {category: category} : {} %}
    {% set __url = absolute_url(path(__route, __params)) %}
    {% if (page|default(1)) > 1 %}
        {{ __url ~ '?page=' ~ page }}
    {% else %}
        {{ __url }}
    {% endif %}
{% endblock %}

{% block structured_data %}
    {{ parent() }}
    {% set __ango_json_opts = constant('JSON_UNESCAPED_SLASHES') b-or constant('JSON_UNESCAPED_UNICODE') %}
    {% set __page_url = block('canonical_url')|trim %}
    {% set __seo_keywords = '' %}
    {% if category == 'hair' %}
        {% set __seo_keywords = 'Վարսահարդարում Երևանում, վարսավիր, մազերի խնամք, Վարսահարդարման գներ, varsahardarum yerevanum, varsavir yerevan, mazeri xnamq' %}
    {% elseif category == 'nails' %}
        {% set __seo_keywords = 'Մատնահարդարում Երևանում, մանիկյուր, շելլակ, գել լաք, маникюр Ереван, шеллак, гель лак, matnahardarum yerevanum, manikyur yerevan, shellac manikyur' %}
    {% elseif category == 'pedicure' %}
        {% set __seo_keywords = 'Ոտնահարդարում Երևանում, pedicure, պեդիկյուր, педикюр Ереван, otnahardarum yerevanum, pedicure yerevan' %}
    {% elseif category == 'makeup' %}
        {% set __seo_keywords = 'Դիմահարդարում Երևանում, հարսանեկան դիմահարդարում, makeup artist, dimahardarum yerevanum, harsanekan dimahardarum, makeup artist yerevan' %}
    {% else %}
        {% set __seo_keywords = 'Գեղեցկության սրահ Երևանում, Beauty salon Yerevan, ծառայություններ, գներ, առցանց ամրագրում, վարսահարդարում, մատնահարդարում, ոտնահարդարում (pedicure), դիմահարդարում' %}
    {% endif %}

    {% set __pos = ((page|default(1) - 1) * (perPage|default(12))) %}
    {% set __items = [] %}
    {% for _cat, cards in groupedServices %}
        {% for card in cards %}
            {% set __pos = __pos + 1 %}
            {% set s = card.service %}
            {% set __items = __items|merge([{
                '@type': 'ListItem',
                'position': __pos,
                'item': {
                    '@type': 'Service',
                    'name': s.name,
                    'url': absolute_url(path('app_service_show', {id: s.id, slug: card.slug}))
                }
            }]) %}
        {% endfor %}
    {% endfor %}

    {% set __breadcrumbs = {
        '@type': 'BreadcrumbList',
        'itemListElement': [
            {
                '@type': 'ListItem',
                'position': 1,
                'name': 'Գլխավոր',
                'item': absolute_url(path('app_home'))
            },
            {
                '@type': 'ListItem',
                'position': 2,
                'name': categoryLabel,
                'item': __page_url
            }
        ]
    } %}

    <script type="application/ld+json">
        {{ {
            '@context': 'https://schema.org',
            '@graph': [
                __breadcrumbs,
                ({
                    '@type': 'CollectionPage',
                    'name': categoryLabel,
                    'url': __page_url,
                    'inLanguage': 'hy-AM'
                } | merge(__seo_keywords ? {'keywords': __seo_keywords} : {})),
                {
                    '@type': 'ItemList',
                    'name': categoryLabel,
                    'itemListElement': __items
                }
            ]
        }|json_encode(__ango_json_opts)|raw }}
    </script>
{% endblock %}

{% block body %}
    <div class="bg-white">
        <div class="container mx-auto px-4 py-12">
            <nav class="text-sm text-gray-500 mb-6">
                <a href="{{ path('app_home') }}" class="hover:text-pink-600 transition">Գլխավոր</a>
                <span class="mx-2">/</span>
                <span class="text-gray-800 font-semibold">{{ categoryLabel }}</span>
            </nav>

            <div class="flex flex-col lg:flex-row lg:items-end lg:justify-between gap-6 mb-10">
                <div>
                    <h1 class="text-3xl md:text-4xl font-bold text-gray-900">
                        {{ category ? categoryLabel : 'Մեր Ծառայությունները' }}
                    </h1>
                    <p class="text-gray-500 mt-2">
                        {% if category %}
                            Տեսեք {{ categoryLabel|lower }} ծառայությունները՝ գներով և տևողությամբ
                        {% else %}
                            Տեսեք բոլոր ծառայությունները՝ կատեգորիաներով, գներով և տևողությամբ
                        {% endif %}
                    </p>
                </div>

                <div class="w-full lg:w-auto">
                    <div class="border-b border-gray-200">
                        <nav class="-mb-px flex items-center space-x-10 overflow-x-auto whitespace-nowrap">
                            {% set tabs = [
                                { key: null, label: 'Բոլորը', href: path('app_service_index') },
                                { key: 'hair', label: 'Վարսահարդարում', href: path('app_service_category', {category: 'hair'}) },
                                { key: 'makeup', label: 'Դիմահարդարում', href: path('app_service_category', {category: 'makeup'}) },
                                { key: 'nails', label: 'Մատնահարդարում', href: path('app_service_category', {category: 'nails'}) },
                                { key: 'pedicure', label: 'Ոտնահարդարում', href: path('app_service_category', {category: 'pedicure'}) }
                            ] %}
                            {% for t in tabs %}
                                {% set isActive = (category is same as(t.key)) %}
                                <a href="{{ t.href }}"
                                   class="px-2 py-2 text-sm font-semibold border-b-2 transition {{ isActive ? 'text-gray-900 border-gray-900' : 'text-gray-500 border-transparent hover:text-gray-900 hover:border-gray-300' }}">
                                    {{ t.label }}
                                </a>
                            {% endfor %}
                        </nav>
                    </div>
                </div>
            </div>

            {% if serviceCards is empty %}
                <div class="text-center py-16 text-gray-500">
                    Այս բաժնում դեռևս ծառայություններ չկան։
                </div>
            {% else %}
                {% for catKey, cards in groupedServices %}
                    {% if cards is not empty %}
                        {% set heading = categoryLabels[catKey]|default(catKey) %}
                        <section class="mb-14">
                            {% if not category %}
                                <div class="flex items-center justify-between mb-6">
                                    <h2 class="text-2xl font-bold text-gray-900">{{ heading }}</h2>
                                    <a href="{{ path('app_service_category', {category: catKey}) }}" class="text-sm font-semibold text-pink-600 hover:underline">
                                        Տեսնել բոլորը →
                                    </a>
                                </div>
                            {% else %}
                                <h2 class="text-2xl font-bold text-gray-900 mb-6">{{ heading }}</h2>
                            {% endif %}

                            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                {% for card in cards %}
                                    {% set s = card.service %}
                                    <div class="group relative bg-white rounded-2xl border border-gray-100 shadow-sm hover:shadow-xl transition p-6">
                                        <div class="flex items-start justify-between gap-4">
                                            <div class="min-w-0">
                                                <div class="text-lg font-bold text-gray-900 group-hover:text-pink-600 transition truncate">
                                                    {{ s.name }}
                                                </div>
                                            </div>

                                            <div class="text-right shrink-0">
                                                <div class="text-xs text-gray-500">Գին</div>
                                                <div class="text-xl font-extrabold text-gray-900 mt-0.5 whitespace-nowrap">
                                                    {{ s.price }} ֏
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mt-5 flex items-center justify-between">
                                            <div class="text-xs font-semibold bg-pink-50 text-pink-700 px-3 py-1 rounded-full border border-pink-100">
                                                {{ heading }}
                                            </div>
                                            <div class="flex items-center gap-2">
                                                <a href="#booking"
                                                   data-category="{{ s.category }}"
                                                   data-service-id="{{ s.id }}"
                                                   class="relative z-20 inline-flex items-center justify-center rounded-full bg-gray-900 text-white px-4 py-2 text-xs font-bold hover:bg-pink-600 transition focus:outline-none focus-visible:ring-2 focus-visible:ring-pink-200">
                                                    Ամրագրել
                                                </a>
                                                <div class="text-sm font-semibold text-gray-900 group-hover:text-pink-600 transition">
                                                    Տեսնել →
                                                </div>
                                            </div>
                                        </div>

                                <a href="{{ path('app_service_show', {id: s.id, slug: card.slug}) }}"
                                           class="absolute inset-0 z-10 rounded-2xl focus:outline-none focus-visible:ring-2 focus-visible:ring-pink-200"
                                           aria-label="{{ s.name }} ծառայություն"></a>
                                    </div>
                                {% endfor %}
                            </div>
                        </section>
                    {% endif %}
                {% endfor %}
            {% endif %}

            {% if totalPages|default(1) > 1 %}
                {% set __route = category ? 'app_service_category' : 'app_service_index' %}
                {% set __params = category ? {category: category} : {} %}
                {% set __base = path(__route, __params) %}
                <nav class="mt-6 flex flex-wrap items-center justify-center gap-2" aria-label="Pagination">
                    {% set __prev_page = page - 1 %}
                    {% set __prev_href = __prev_page > 1 ? (__base ~ '?page=' ~ __prev_page) : __base %}
                    <a href="{{ __prev_href }}" class="px-3 py-2 rounded-lg border text-sm {{ page > 1 ? 'bg-white text-gray-700 hover:bg-gray-50' : 'pointer-events-none text-gray-300 bg-gray-50' }}">‹</a>

                    {% for p in 1..totalPages %}
                        {% set __href = p > 1 ? (__base ~ '?page=' ~ p) : __base %}
                        <a href="{{ __href }}" class="px-3 py-2 rounded-lg border text-sm {{ p == page ? 'bg-gray-900 text-white border-gray-900' : 'bg-white text-gray-700 hover:bg-gray-50' }}">{{ p }}</a>
                    {% endfor %}

                    {% set __next_page = page + 1 %}
                    {% set __next_href = __base ~ '?page=' ~ __next_page %}
                    <a href="{{ __next_href }}" class="px-3 py-2 rounded-lg border text-sm {{ page < totalPages ? 'bg-white text-gray-700 hover:bg-gray-50' : 'pointer-events-none text-gray-300 bg-gray-50' }}">›</a>
                </nav>
            {% endif %}

        </div>
    </div>
{% endblock %}


